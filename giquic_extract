 SUBROUTINE  set_provider (null )
  SELECT INTO "proc:"
   FROM (prsnl_alias pa ),
    (prsnl pr )
   PLAN (pa
    WHERE (pa.alias =  $NPI )
     AND (pa.prsnl_alias_type_cd = npi_cd )
     AND (pa.end_effective_dt_tm >= cnvtdatetime (curdate ,curtime3 ) )
     AND (pa.end_effective_dt_tm > cnvtdatetime (curdate ,curtime3 ) ) )
    JOIN (pr
    WHERE (pr.person_id = pa.person_id ) AND (pr.logical_domain_id = 0.00 ) )
   HEAD pa.person_id
    rec->phy_id = pa.person_id ,rec->phys_id_npi = pa.alias ,rec->phy_name = pr.name_full_formatted
   WITH nocounter
 END
