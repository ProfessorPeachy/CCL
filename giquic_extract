 SUBROUTINE  get_path_results (parentid ,eidx, qidx)
 SELECT INTO "proc:"
 FROM
  clinical_event ce
 WHERE (ce.encntr_id = rec->enc[eidx ].enc_id)
 	AND (ce.parent_event_id = parentid) ;e.g. 801856457 in C137
    AND (ce.parent_event_id != ce.event_id )
    AND (ce.valid_until_dt_tm >= cnvtdatetime (curdate ,curtime3 ) )
    AND (ce.publish_flag = 1 )
    AND (ce.view_level = 1 )
    AND (ce.result_status_cd IN (auth_cd , mod_cd , alter_cd ) )
        AND (ce.event_cd IN (
           adenom_cd ,
           adpolyp1_cd ,
           adpolyp2_cd ,
           adpolyp3_cd ,
           adenocarcinoma_cd ,
           serrated_lesions_cd ,
           serrated_lesion1_cd ,
           serrated_lesion2_cd ,
           hyperplastic_cd ,
           pathology_other_cd,
           fu_interval_path_cd,
           fu_interval_path_cd1,
           fu_interval_path_cd2,
           fu_interval_path_cd3,
           fu_interval_path_cd4,
           fu_interval_path_cd5,
           fu_interval_path_cd6,
           fu_interval_path_cd7,
           fu_interval_path_cd8,
           fu_interval_path_cd9,
           fu_interval_path_cd10 ) )
  ORDER BY
   ce.encntr_id ,
   ce.updt_dt_tm ,
   ce.event_id
  HEAD REPORT
   ecnt = 0
  HEAD ce.event_id
   IF (debug = 1)
    call echo(build("DEBUG: get_path_results(): event_id=" ,ce.event_id))
   ENDIF ,
   CASE (ce.event_cd)
    OF adenom_cd : 				; field 67
     rec->enc[eidx ].qual_pn[qidx ].path_adenom_polyp = "1"
    OF adpolyp1_cd :			; field 68
      rec->enc[eidx ].qual_pn[qidx ].path_adpolyp1 = "1"
    OF adpolyp2_cd :			; field 69
      rec->enc[eidx ].qual_pn[qidx ].path_adpolyp2 = "1"
    OF adpolyp3_cd :			; field 70
      rec->enc[eidx ].qual_pn[qidx ].path_adpolyp3 = "1"
    OF hyperplastic_cd :		; field 71
      rec->enc[eidx ].qual_pn[qidx ].path_hyperpl_polyp = "1"
    OF adenocarcinoma_cd :		; field 72
      rec->enc[eidx ].qual_pn[qidx ].path_adenocar = "1"
    OF pathology_other_cd :		; field 73, 74
      rec->enc[eidx ].qual_pn[qidx ].path_other = "1"
      rec->enc[eidx ].qual_pn[qidx ].path_other_text = substring (1 ,75 ,ce.result_val )
      IF (debug = 1)
      	call echo(build("DEBUG: get_path_results(): path_other_text =", rec->enc[eidx ].qual_pn[qidx ].path_other_text ) )
      ENDIF
    OF serrated_lesions_cd :	; field 99
      rec->enc[eidx ].qual_pn[qidx ].path_serrated = "1"
    OF serrated_lesion1_cd :	; field 100
      rec->enc[eidx ].qual_pn[qidx ].path_sslesion1 = "1"
    OF serrated_lesion2_cd :	; field 101
      rec->enc[eidx ].qual_pn[qidx ].path_sslesion2 = "1"
    OF fu_interval_path_cd :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "0"
    OF fu_interval_path_cd1 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "1"
    OF fu_interval_path_cd2 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "2"
    OF fu_interval_path_cd3 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "3"
    OF fu_interval_path_cd4 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "4"
    OF fu_interval_path_cd5 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "5"
    OF fu_interval_path_cd6 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "6"
    OF fu_interval_path_cd7 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "7"
    OF fu_interval_path_cd8 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "8"
    OF fu_interval_path_cd9 :
     rec->enc[eidx ].qual_pn[qidx ].fu_interval = "9"
    OF fu_interval_path_cd10 :
      rec->enc[eidx ].qual_pn[qidx ].fu_interval = "10"
      rec->enc[eidx ].qual_pn[qidx ].interval_other_text = substring (1 ,50 ,ce.result_val )
      IF (debug = 1)
       call echo(build("DEBUG: get_path_results(): interval_other_text =",rec->enc[eidx ].qual_pn[qidx ].interval_other_text ) )
      ENDIF
    ENDCASE
  FOOT  ce.event_id
   IF ((rec->enc[eidx ].qual_pn[qidx ].path_adenocar != "1") )
    rec->enc[eidx ].qual_pn[qidx ].path_adenocar = " "
   ENDIF
   IF ((rec->enc[eidx ].qual_pn[qidx ].path_adenom_polyp != "1") )
    rec->enc[eidx ].qual_pn[qidx ].path_adenom_polyp = " "
   ENDIF
   IF ((rec->enc[eidx ].qual_pn[qidx ].path_adpolyp1 != "1") )
    rec->enc[eidx ].qual_pn[qidx ].path_adpolyp1 = " "
   ENDIF
   IF ((rec->enc[eidx ].qual_pn[qidx ].path_adpolyp2 != "1") )
    rec->enc[eidx ].qual_pn[qidx ].path_adpolyp2 = " "
   ENDIF
   IF ((rec->enc[eidx ].qual_pn[qidx ].path_adpolyp3 != "1") )
    rec->enc[eidx ].qual_pn[qidx ].path_adpolyp3 = " "
   ENDIF
   IF ((rec->enc[eidx ].qual_pn[qidx ].path_hyperpl_polyp != "1") )
    rec->enc[eidx ].qual_pn[qidx ].path_hyperpl_polyp = " "
   ENDIF
   IF ((rec->enc[eidx ].qual_pn[qidx ].path_other != "1") )
    rec->enc[eidx ].qual_pn[qidx ].path_other = " "
   ENDIF
  WITH nocounter

  IF ((size (rec->enc ,5 ) = 0 ) )
   GO TO exit_script
  ENDIF
  
  
 END ;subroutine
 
 

 
;;;;*** PROCEDURE NOTE QUERY ***
 SELECT INTO "proc:"
  FROM
   (scr_pattern sp ),	; Procedure EP
   (scd_story_pattern ssp ),	; Procedure Note
   (scd_story ss ),		; Procedure Note
   (clinical_event ce ),
   (clinical_event ce1 ),
   (encounter e ),
   (person p ),
   (encntr_alias ea ),
   (address a ),
   (clinical_event ce2 ),
   (ce_date_result ced ),
   (ce_blob cb )
  PLAN (sp
   WHERE (sp.pattern_type_cd = enctr_pathway_cd )
    AND (sp.cki_identifier = $EP_CKI_IDENTIFIER )		; Procedure EP
   JOIN (ssp											; Procedure EP
   WHERE (ssp.scr_pattern_id = sp.scr_pattern_id )
    AND (ssp.pattern_type_cd = enctr_pathway_cd ) )
   JOIN (ss												; Procedure Note
   WHERE (ss.scd_story_id = ssp.scd_story_id )
    AND (ss.author_id = rec->phy_id )
    AND (ss.updt_dt_tm BETWEEN cnvtdatetime (sdt ) AND cnvtdatetime (cnvtdate (edt ) ,235959 ) ) )
   JOIN (ce ;clinical event of the note type used to sign the note
   WHERE (ce.event_id = ss.event_id )
   	;AND (ce.updt_dt_tm BETWEEN cnvtdatetime (sdt ) AND cnvtdatetime (cnvtdate (edt ) ,235959 ) )
   	AND (ce.result_status_cd IN (auth_cd , mod_cd , alter_cd ) )
   	AND (ce.valid_until_dt_tm >= cnvtdatetime (curdate ,curtime3 ) )
   	AND (ce.publish_flag = 1 )
   	AND (ce.view_level = 1 ) )
   JOIN (ce1 ;parent clinical event of this note
   WHERE (ce1.parent_event_id = ce.event_id )
    AND (ce.updt_dt_tm BETWEEN cnvtdatetime (sdt ) AND cnvtdatetime (cnvtdate (edt ) ,235959 ) )
    AND (ce1.parent_event_id != ce1.event_id )
    AND (ce1.result_status_cd IN (auth_cd , mod_cd , alter_cd ) )
    AND (ce1.valid_until_dt_tm >= cnvtdatetime (curdate ,curtime3 ) )
    AND (ce1.publish_flag = 1 )
    AND (ce1.view_level = 1 ) )
   JOIN (e
   WHERE (e.encntr_id = ce.encntr_id )
    AND (e.end_effective_dt_tm >= cnvtdatetime (curdate ,curtime3) )
    AND (e.active_ind = 1 ) )
   JOIN (p
   WHERE (p.person_id = e.person_id )
    AND (p.sex_cd IN (male_cd , female_cd ) ) )
   JOIN (ea
   WHERE (ea.encntr_id = e.encntr_id )
    AND (ea.encntr_alias_type_cd = mrn_cd )
    AND (ea.end_effective_dt_tm >= cnvtdatetime (curdate ,curtime3 ) ) )
   JOIN (a
   WHERE (a.parent_entity_id = p.person_id )
    AND (a.parent_entity_name = "PERSON" )
    AND (a.active_ind = 1 )
    AND (a.end_effective_dt_tm >= cnvtdatetime (curdate ,curtime3 ) )
    AND (a.address_type_cd = home_address_cd )
    AND (a.address_type_seq = 1 ) )
   JOIN (ce2
   WHERE (ce2.parent_event_id = ce1.event_id )
    AND (ce.updt_dt_tm BETWEEN cnvtdatetime (sdt ) AND cnvtdatetime (cnvtdate (edt ) ,235959 ) )
    AND (ce2.result_status_cd IN (auth_cd , mod_cd , alter_cd ) )
