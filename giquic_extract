 ;;;***get_path_result : determine whether there is a parent CE that was documented with a child CE that means
 ;;;						"pathology result for X procedure date" that matches the original procedure date
 ;;;
 
 SUBROUTINE get_path_result (procdt, myecnt ,myqcnt)
 	DECLARE num_path_results = i4
 	DECLARE parid = f8
 	SELECT INTO "proc:"
  	FROM
        clinical_event ce,
        ce_date_result ced
        WHERE (ce.event_cd = proc_date_path_cd) ;563288425 proc_date_path_cd
           	AND (ce.encntr_id = rec->enc[ myecnt].enc_id )
           	AND (ce.parent_event_id != ce.event_id )
           	AND (ce.valid_until_dt_tm >= cnvtdatetime (curdate ,curtime3 ) )
           	AND (ce.publish_flag = 1 )
           	AND (ce.view_level = 1 )
           	AND (ce.result_status_cd != err_cd) ;exclude in-error results/notes
           	AND (format(ced.result_dt_tm,"MM/DD/YYYY;;q") = procdt) ;matches original procedure date documented?
                AND (ced.event_id = ce.event_id)
  	HEAD REPORT
   	 acnt = 0
  	HEAD ce.parent_event_id
   	 acnt = (acnt + 1 ) ,
   	 IF ( debug = 1 )
         	call echo(build2("DEBUG: get_path_result(): "
          	 ,acnt, " pathology results found for proc_date={" ,procdt ,"}") )
          	call echo(build("DEBUG: get_path_result(): ce.parent_event_id="
          	 ,ce.parent_event_id ) )
          	call echo(build("DEBUG: get_path_result(): ce.encntr_id="
          	 ,ce.encntr_id ) )
         ENDIF ,
   	 IF ((acnt = 1) AND (ce.parent_event_id != 0) )
           	num_path_results = 1
           	parid = ce.parent_event_id 
 		 		;MOD002 update record_type to "2" to indicate that pathology results were resulted
