	2 second_payer = vc
	2 payor_grouping = vc
	2 prescribe_personnel = vc
    2 prescribe_physician = vc
    2 prescriber_position = vc
	2 pat_name = vc
	2 pat_dob = vc
	2 prescriber_npi = vc
	2 strength = vc
	2 strength_unit = vc
